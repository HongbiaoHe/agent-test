{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/lint-changed.sh\"",
            "timeout": 60,
            "statusMessage": "eslint 检查改动文件…"
          }
        ]
      }
    ]
  }
}
