PORT=3101
CORS_ORIGIN=http://localhost:3100
DATABASE_URL=mysql://root:dev@localhost:3306/agent
REDIS_URL=redis://localhost:6379
GOOGLE_GENAI_MODEL=gemini-2.0-flash
# 你的 Gemini API key，留空待填
GOOGLE_API_KEY=
# WebAuthn / Passkey：RP_ID=可访问域名（隧道演示填隧道域名，本机填 localhost），ORIGIN 带协议
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=AgentSpark
WEBAUTHN_ORIGIN=http://localhost:3100

# JWT Auth Secret (Required, backend will fail to start if not provided)
AUTH_JWT_SECRET=

# Resend API Key for sending verification code email (Replace re_xxxxxxxxx with your real key)
RESEND_API_KEY=re_xxxxxxxxx

# ── 技能（skills）──
# 内置技能目录（缺省 apps/backend/skills）与用户安装技能根目录（缺省 apps/backend/data/skills）
# SKILLS_DIR=
# SKILLS_DATA_DIR=

# ── Daytona 云沙箱（技能脚本 execute 执行；留空则回退无执行能力的 StateBackend）──
# 注册 https://app.daytona.io 获取（免费层 $200 额度）
DAYTONA_API_KEY=

# ── 生图 / 生视频（Google genai，与 GOOGLE_API_KEY 同 key）──
# 资产目录缺省 apps/backend/data/media
# MEDIA_DATA_DIR=
# MEDIA_IMAGE_MODEL=gemini-3.1-flash-image-preview
# MEDIA_VIDEO_MODEL=veo-3.1-generate-preview
